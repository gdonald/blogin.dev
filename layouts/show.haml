.card
  .card-body
    %article
      %h1.mb-4= title
      - if has-toc
        %nav.toc.mb-4.p-3.bg-body-tertiary.rounded
          %h2.h6.text-muted.text-uppercase Contents
          != toc-html
      != body
      - if has-tags
        %nav.tags.mt-4
          - for tags -> $tag
            %a.badge.text-bg-secondary.text-decoration-none.me-1{href: "#{$tag<url>}"}= $tag<name>
    != post-nav-html
